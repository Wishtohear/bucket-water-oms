<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bucketwater.oms.module.admin.mapper.RegionMapper">

    <select id="selectByParentCode" resultType="com.bucketwater.oms.module.admin.entity.Region">
        SELECT * FROM region
        WHERE parent_code = #{parentCode}
        ORDER BY sort ASC, code ASC
    </select>

    <select id="selectByLevel" resultType="com.bucketwater.oms.module.admin.entity.Region">
        SELECT * FROM region
        WHERE level = #{level}
        ORDER BY sort ASC, code ASC
    </select>

    <select id="selectByStatus" resultType="com.bucketwater.oms.module.admin.entity.Region">
        SELECT * FROM region
        WHERE status = #{status}
        ORDER BY sort ASC, code ASC
    </select>

</mapper>
